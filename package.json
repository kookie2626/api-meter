{
  "name": "api-meter",
  "productName": "API Meter",
  "version": "1.3.3",
  "description": "Menu Bar / System Tray API Meter",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/kookie2626/api-meter.git"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.keunlee.api-meter",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "title": "Install API Meter",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kookie2626",
        "repo": "api-meter"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "menubar": "^9.5.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  }
}
